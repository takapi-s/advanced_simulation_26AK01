#!/bin/bash
#PBS -N himeno_task1
#PBS -q Eduq
#PBS -l select=1:ncpus=8:mem=16gb
#PBS -l walltime=2:00:00
#PBS -j oe

ulimit -c 0
. /etc/profile
module load intel/2025

cd "$PBS_O_WORKDIR"

echo "=== Node info ==="
hostname
date
lscpu | head -20
free -h 2>/dev/null || true
echo ""

bash scripts/download_sources.sh
bash scripts/run_all_tasks.sh
