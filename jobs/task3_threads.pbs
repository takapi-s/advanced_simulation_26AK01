#!/bin/bash
#PBS -N himeno_task3
#PBS -q Eduq
#PBS -l select=1:ncpus=8:mem=16gb
#PBS -l walltime=1:00:00
#PBS -j oe

ulimit -c 0
. /etc/profile
module load intel/2025

cd "$PBS_O_WORKDIR"

for t in 1 2 4 8; do
  OMP_NUM_THREADS="$t" OPT=-O2 GRID=S \
    bash scripts/run_benchmark.sh "results/raw/task3_t${t}.log"
done

bash scripts/parse_output.sh results/raw/task3_*.log
